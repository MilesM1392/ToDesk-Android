<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
xmlns:android="http://schemas.android.com/apk/res/android"
xmlns:app="http://schemas.android.com/apk/res-auto"
xmlns:tools="http://schemas.android.com/tools"
android:layout_width="match_parent"
android:layout_height="wrap_content"
android:layout_marginStart="0dp"
android:layout_marginEnd="0dp"
android:layout_marginTop="0dp"
android:layout_marginBottom="0dp"
app:cardCornerRadius="0dp"
app:cardElevation="0dp"
    android:backgroundTint="@color/card_devoir"
android:foreground="?attr/selectableItemBackground">

<androidx.constraintlayout.widget.ConstraintLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="20dp"
    android:paddingEnd="20dp"
    android:paddingTop="20dp"
    android:backgroundTint="@color/card_devoir"
    android:paddingBottom="20dp">

    <!-- Left Color Indicator -->
    <View
        android:id="@+id/colorIndicator"
        android:layout_width="6dp"
        android:layout_height="0dp"
        android:background="@drawable/subject_color_gradient"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

    <!-- Subject Badge - Top Right -->
    <TextView
        android:id="@+id/subjectBadge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:textSize="11sp"
        android:textColor="@color/sec_text"
        android:background="@drawable/subject_badge_background"
        android:fontFamily="sans-serif-medium"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="Mathématiques"/>

    <!-- Date with Icon -->
    <ImageView
        android:id="@+id/clockIcon"
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:src="@drawable/ic_clock"
        android:layout_marginStart="16dp"
        app:layout_constraintStart_toEndOf="@id/colorIndicator"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/primary_text" />

    <TextView
        android:id="@+id/date"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="6dp"
        android:layout_marginEnd="8dp"
        android:textSize="15sp"
        android:textColor="@color/primary_text"
        android:fontFamily="sans-serif-medium"
        app:layout_constraintStart_toEndOf="@id/clockIcon"
        app:layout_constraintEnd_toStartOf="@id/subjectBadge"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="Demain, 10 Mai"/>

    <!-- Urgent Badge (optional, visibility controlled in adapter)
    <TextView
        android:id="@+id/urgentBadge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:text="Urgent"
        android:textSize="11sp"
        android:textColor="#D4183D"
        android:background="@drawable/urgent_badge_background"
        android:fontFamily="sans-serif-medium"
        android:visibility="gone"
        app:layout_constraintStart_toEndOf="@id/date"
        app:layout_constraintTop_toTopOf="parent"
        tools:visibility="visible"/>
    -->
    <!-- Title/Content -->
    <TextView
        android:id="@+id/title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="8dp"
        android:textSize="15sp"
        android:textColor="@color/primary_text"
        android:fontFamily="sans-serif-medium"
        android:lineSpacingMultiplier="1.3"
        app:layout_constraintStart_toEndOf="@id/colorIndicator"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/date"
        tools:text="Exercices sur les dérivées - Chapitre 5 pages 124-126"/>

</androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>
